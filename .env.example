# OpenAI (server only — never expose to client)
OPENAI_API_KEY=
# Model id (e.g. gpt-4o-mini). Use your project’s approved model name.
# Use the model ID enabled for your API key (e.g. gpt-4o-mini, or your project-specific name).
OPENAI_MODEL=gpt-4o-mini

# Firebase (client — safe to expose with proper Firestore rules)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
